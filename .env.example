# One Car Group Bilverktyg — backend environment.
# gate scans this file at deploy time and provisions each variable by tier.

# --- Tier 2: auto-generated 64-char hex secrets (do NOT set values here) ---
# Staff login password. gate generates a random value; override with a memorable
# one in Studio → Settings → Secrets after the first deploy.
APP_PASSWORD=
# HMAC key backing the signed session cookie (ocg_session).
SESSION_SECRET=

# --- Tier 1: injected by gate (listed for documentation only) ---
# PORT=            # gate sets 3000
# NODE_ENV=        # gate sets production

# --- Optional overrides (sensible defaults in code) ---
# DATA_DIR=/app/data              # persisted volume for records/bookings/inventory cache
# RECORD_TTL_DAYS=7               # share-link record lifetime
# INVENTORY_TTL_MINUTES=60        # how long the cars feed is cached before refresh
# OCG_CARS_URL=https://www.onecargroup.se/wp-json/accesspackage/v1/cars
# LOG_LEVEL=info
